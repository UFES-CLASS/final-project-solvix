<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<AnchorPane prefHeight="650.0" prefWidth="1000.0" stylesheets="@../css/login.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.stockin.controller.LoginController">

    <children>

        <HBox AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

            <!-- LEFT SIDE -->

            <VBox fx:id="leftPane" alignment="CENTER" fillWidth="false" prefHeight="633.0" prefWidth="582.0" spacing="10" styleClass="left-pane" HBox.hgrow="ALWAYS">

                <children>

                    <Label styleClass="logo-title" text="STOCKIN" />

                    <Label styleClass="logo-subtitle" text="Smart Inventory System" />

                    <Region styleClass="divider" />

                    <HBox alignment="CENTER" spacing="8" styleClass="tagline-box">

                        <children>

                            <Label styleClass="tagline" text="Fresh" />

                            <Label styleClass="dot" text="•" />

                            <Label styleClass="tagline" text="Organized" />

                            <Label styleClass="dot" text="•" />

                            <Label styleClass="tagline" text="Efficient" />

                        </children>

                    </HBox>

                </children>

            </VBox>

            <!-- RIGHT SIDE -->

            <VBox alignment="CENTER" prefWidth="500" styleClass="right-pane" HBox.hgrow="ALWAYS">

                <children>

                    <VBox styleClass="form-box" maxWidth="364.0" prefHeight="472.0" prefWidth="364.0" spacing="12">

                        <children>

                            <Label styleClass="welcome-title" text="Welcome!" />

                            <Label styleClass="welcome-sub" text="Login to your account" />

                            <VBox spacing="5">

                                <Label styleClass="field-label" text="Username" />

                                <StackPane alignment="CENTER_LEFT">

                                    <children>

                                        <TextField fx:id="txtUsername" promptText="Enter your username" styleClass="input" />

                                        <SVGPath styleClass="input-icon" translateX="12" content="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-3.33 0-8 1.5-8 4.5V20h16v-1.5c0-3-4.67-4.5-8-4.5z" StackPane.alignment="CENTER_LEFT" />

                                    </children>

                                </StackPane>

                            </VBox>

                            <VBox spacing="5">

                                <Label styleClass="field-label" text="Password" />

                                <StackPane alignment="CENTER_LEFT">

                                    <children>

                                        <PasswordField fx:id="txtPassword" promptText="Enter your password" styleClass="input" />

                                        <SVGPath styleClass="input-icon" translateX="12" content="M12 2a4 4 0 0 0-4 4v3H7a1 1 0 0 0-1 1v9a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1v-9a1 1 0 0 0-1-1h-1V6a4 4 0 0 0-4-4zm0 2a2 2 0 0 1 2 2v3H10V6a2 2 0 0 1 2-2zm0 9a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3z" StackPane.alignment="CENTER_LEFT" />

                                    </children>

                                </StackPane>

                            </VBox>

                            <VBox spacing="5">

                                <Label styleClass="field-label" text="Role" />

                                <ComboBox fx:id="cmbRole" promptText="Select Role" styleClass="combo" maxWidth="Infinity" />

                            </VBox>

                            <Button fx:id="btnLogin" onAction="#login" styleClass="login-button" text="LOGIN" />

                            <Label fx:id="lblStatus" styleClass="status" />

                            <HBox alignment="CENTER_LEFT" spacing="4">

                                <children>

                                    <Label styleClass="help" text="Need help?" />

                                    <Label styleClass="help-link" text="Contact administrator" />

                                </children>

                            </HBox>

                        </children>

                    </VBox>

                </children>

            </VBox>

        </HBox>

    </children>

</AnchorPane>