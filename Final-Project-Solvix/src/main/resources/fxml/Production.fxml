<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.stockin.controller.ProductionController">

    <top>

        <VBox spacing="10">

            <Label text="Production"
                   style="-fx-font-size:22px;
                          -fx-font-weight:bold;"/>

            <GridPane hgap="10" vgap="10">

                <Label text="Produk" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <ComboBox fx:id="cmbProduct" prefWidth="200" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Tanggal Produksi" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                <DatePicker fx:id="dateProduction" prefWidth="150" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                <Label text="Tanggal Kedaluwarsa" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <DatePicker fx:id="dateExpired" prefWidth="150" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Harga Jual" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                <TextField fx:id="txtSellingPrice" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                <Label text="Jumlah Diproduksi" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="txtQuantityProduced" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="Jumlah Terjual" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                <TextField fx:id="txtQuantitySold" GridPane.rowIndex="2" GridPane.columnIndex="3"/>

                <Label text="Catatan" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <TextField fx:id="txtNote" GridPane.rowIndex="3" GridPane.columnIndex="1"
                           GridPane.columnSpan="3"/>

            </GridPane>

            <Separator/>

            <Label text="Bahan Digunakan (opsional, stok akan dikurangi otomatis saat Tambah)"
                   style="-fx-font-weight:bold;"/>

            <GridPane hgap="10" vgap="10">

                <Label text="Material" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <ComboBox fx:id="cmbMaterialUsed" prefWidth="200" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Jumlah Dipakai" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                <TextField fx:id="txtMaterialQtyUsed" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

            </GridPane>

            <HBox spacing="10">

                <Button text="Tambah" onAction="#saveProduction"/>
                <Button text="Ubah" onAction="#updateProduction"/>
                <Button text="Hapus" onAction="#deleteProduction"/>
                <Button text="Reset" onAction="#clearForm"/>

            </HBox>

        </VBox>

    </top>

    <center>

        <TableView fx:id="tableProduction">

            <columns>

                <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                <TableColumn fx:id="colProduct" text="Produk" prefWidth="140"/>
                <TableColumn fx:id="colProdDate" text="Tgl Produksi" prefWidth="100"/>
                <TableColumn fx:id="colExpDate" text="Tgl Kedaluwarsa" prefWidth="110"/>
                <TableColumn fx:id="colProduced" text="Diproduksi" prefWidth="90"/>
                <TableColumn fx:id="colSold" text="Terjual" prefWidth="80"/>
                <TableColumn fx:id="colPrice" text="Harga Jual" prefWidth="100"/>
                <TableColumn fx:id="colRevenue" text="Pendapatan" prefWidth="110"/>
                <TableColumn fx:id="colNote" text="Catatan" prefWidth="140"/>

            </columns>

        </TableView>

    </center>

    <padding>
        <Insets top="20" right="20" left="20" bottom="20"/>
    </padding>

</BorderPane>
