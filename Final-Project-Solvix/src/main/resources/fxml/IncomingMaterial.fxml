<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true"
            style="-fx-background-color:transparent; -fx-background: transparent;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.stockin.controller.IncomingMaterialController">

    <content>

        <VBox spacing="20" style="-fx-background-color:transparent;">

            <padding>
                <Insets top="0" right="4" bottom="20" left="0"/>
            </padding>

            <Label text="Incoming Material Management" styleClass="page-title"/>

            <!-- ================= ADD / EDIT FORM ================= -->
            <HBox spacing="20">

                <!-- LEFT COLUMN -->
                <VBox spacing="16" styleClass="card" HBox.hgrow="ALWAYS" maxWidth="Infinity">

                    <VBox spacing="6">
                        <Label text="Material" styleClass="form-label"/>
                        <ComboBox fx:id="cmbMaterial" promptText="Select material" maxWidth="Infinity"
                                  styleClass="combo-box"/>
                    </VBox>

                    <HBox spacing="20">

                        <VBox spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                            <Label text="Quantity" styleClass="form-label"/>
                            <TextField fx:id="txtQuantity" promptText="0" styleClass="text-field"/>
                        </VBox>

                        <VBox spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                            <Label text="Unit" styleClass="form-label"/>
                            <TextField fx:id="txtUnit" promptText="pcs" editable="false" styleClass="text-field"/>
                        </VBox>

                    </HBox>

                    <HBox spacing="20">

                        <VBox spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                            <Label text="Unit Price" styleClass="form-label"/>
                            <TextField fx:id="txtUnitPrice" promptText="0" styleClass="text-field"/>
                        </VBox>

                        <VBox spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                            <Label text="Total Price" styleClass="form-label"/>
                            <TextField fx:id="txtTotalPrice" editable="false" focusTraversable="false"
                                       styleClass="text-field, text-field-readonly"/>
                        </VBox>

                    </HBox>

                </VBox>

                <!-- RIGHT COLUMN -->
                <VBox spacing="16" styleClass="card" HBox.hgrow="ALWAYS" maxWidth="Infinity">

                    <VBox spacing="6">
                        <Label text="Incoming Date" styleClass="form-label"/>
                        <DatePicker fx:id="dateIncoming" maxWidth="Infinity" styleClass="text-field"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Supplier" styleClass="form-label"/>
                        <TextField fx:id="txtSupplier" promptText="Supplier name" styleClass="text-field"/>
                    </VBox>

                    <VBox spacing="6" VBox.vgrow="ALWAYS">
                        <Label text="Note" styleClass="form-label"/>
                        <TextArea fx:id="txtNote" promptText="Note" wrapText="true"
                                  prefRowCount="3" styleClass="text-area" VBox.vgrow="ALWAYS"/>
                    </VBox>

                </VBox>

            </HBox>

            <!-- ================= ACTION BUTTONS ================= -->
            <HBox spacing="14">

                <Button text="Add New Record" onAction="#saveIncoming" styleClass="btn-success"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity"/>

                <Button text="Update Existing" onAction="#updateIncoming" styleClass="btn-primary"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity"/>

                <Button text="Delete Record" onAction="#deleteIncoming" styleClass="btn-danger"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity"/>

                <Button text="Clear Form" onAction="#clearForm" styleClass="btn-neutral"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity"/>

            </HBox>

            <!-- ================= REGISTRY TABLE ================= -->
            <VBox spacing="14" styleClass="card">

                <Label text="Incoming Material Registry" styleClass="panel-title"/>

                <TableView fx:id="tableIncoming" prefHeight="360" minHeight="240" VBox.vgrow="ALWAYS"
                           styleClass="table-view">

                    <columns>

                        <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="colMaterial" text="Material" prefWidth="120"/>
                        <TableColumn fx:id="colDate" text="Incoming Date" prefWidth="110"/>
                        <TableColumn fx:id="colQty" text="Quantity" prefWidth="80"/>
                        <TableColumn fx:id="colUnit" text="Unit" prefWidth="60"/>
                        <TableColumn fx:id="colUnitPrice" text="Unit Price" prefWidth="90"/>
                        <TableColumn fx:id="colTotalPrice" text="Total Price" prefWidth="100"/>
                        <TableColumn fx:id="colSupplier" text="Supplier" prefWidth="130"/>
                        <TableColumn fx:id="colNote" text="Note" prefWidth="180"/>
                        <TableColumn fx:id="colActions" text="Actions" prefWidth="90" sortable="false"/>

                    </columns>

                </TableView>

            </VBox>

        </VBox>

    </content>

</ScrollPane>
