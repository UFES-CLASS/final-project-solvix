<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.stockin.controller.IncomingMaterialController">

    <top>

        <VBox spacing="10">

            <Label text="Incoming Material"
                   style="-fx-font-size:22px;
                          -fx-font-weight:bold;"/>

            <GridPane hgap="10" vgap="10">

                <Label text="Material" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <ComboBox fx:id="cmbMaterial" prefWidth="220"
                          GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Incoming Date" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                <DatePicker fx:id="dateIncoming" prefWidth="150"
                            GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                <Label text="Quantity" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="txtQuantity" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Unit Price" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                <TextField fx:id="txtUnitPrice" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                <Label text="Total Price" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="txtTotalPrice" editable="false" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="Supplier" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                <TextField fx:id="txtSupplier" GridPane.rowIndex="2" GridPane.columnIndex="3"/>

                <Label text="Note" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <TextField fx:id="txtNote" GridPane.rowIndex="3" GridPane.columnIndex="1"
                           GridPane.columnSpan="3"/>

            </GridPane>

            <HBox spacing="10">

                <Button text="Add" onAction="#saveIncoming"/>
                <Button text="Update" onAction="#updateIncoming"/>
                <Button text="Delete" onAction="#deleteIncoming"/>
                <Button text="Reset" onAction="#clearForm"/>

            </HBox>

        </VBox>

    </top>

    <center>

        <TableView fx:id="tableIncoming">

            <columns>

                <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                <TableColumn fx:id="colMaterial" text="Material" prefWidth="150"/>
                <TableColumn fx:id="colDate" text="Incoming Date" prefWidth="100"/>
                <TableColumn fx:id="colQty" text="Quantity" prefWidth="80"/>
                <TableColumn fx:id="colUnit" text="Unit" prefWidth="70"/>
                <TableColumn fx:id="colUnitPrice" text="Unit Price" prefWidth="110"/>
                <TableColumn fx:id="colTotalPrice" text="Total Price" prefWidth="110"/>
                <TableColumn fx:id="colSupplier" text="Supplier" prefWidth="120"/>
                <TableColumn fx:id="colNote" text="Note" prefWidth="150"/>

            </columns>

        </TableView>

    </center>

    <padding>
        <Insets top="20" right="20" left="20" bottom="20"/>
    </padding>

</BorderPane>
