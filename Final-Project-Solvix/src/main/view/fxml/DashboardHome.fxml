<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.AreaChart?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true"
            style="-fx-background-color:transparent; -fx-background: transparent;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.stockin.controller.DashboardHomeController">

    <content>

        <VBox spacing="20" style="-fx-background-color:transparent;">

            <padding>
                <Insets top="0" right="4" bottom="20" left="0"/>
            </padding>

            <!-- ================= HEADER ================= -->
            <HBox alignment="CENTER_LEFT" spacing="12">

                <Label text="Dashboard" styleClass="page-title"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Label text="Date Range" styleClass="date-range-label"/>

                <HBox spacing="4" styleClass="date-range-group">
                    <ToggleButton fx:id="btnRangeToday" text="Today" styleClass="date-range-btn"/>
                    <ToggleButton fx:id="btnRangeWeek" text="Last 7 Days" styleClass="date-range-btn"/>
                    <ToggleButton fx:id="btnRangeMonth" text="This Month" styleClass="date-range-btn"/>
                </HBox>

            </HBox>

            <!-- ================= STAT CARDS ================= -->
            <HBox spacing="15">

                <VBox spacing="8" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="card">
                    <Label text="Total Material" styleClass="card-title"/>
                    <Label fx:id="lblMaterial" text="0" styleClass="card-value"/>
                </VBox>

                <VBox spacing="8" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="card">
                    <Label text="Total Product" styleClass="card-title"/>
                    <Label fx:id="lblProduct" text="0" styleClass="card-value"/>
                </VBox>

                <VBox spacing="8" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="card">
                    <Label text="Low Stock Items" styleClass="card-title"/>
                    <Label fx:id="lblLowStock" text="0" styleClass="card-value" style="-fx-text-fill:#E53935;"/>
                </VBox>

                <VBox spacing="8" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="card">
                    <Label text="Incoming Today" styleClass="card-title"/>
                    <Label fx:id="lblIncoming" text="0" styleClass="card-value"/>
                </VBox>

                <VBox spacing="8" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="card, card-highlight">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Active Production" styleClass="card-title, card-title-white"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="&#9881;" styleClass="card-corner-icon"/>
                    </HBox>
                    <Label fx:id="lblActiveProduction" text="0" styleClass="card-value, card-value-white"/>
                </VBox>

                <VBox spacing="8" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="card">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Stock Asset Value" styleClass="card-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="&#164;" styleClass="card-corner-icon-green"/>
                    </HBox>
                    <Label fx:id="lblStockValue" text="Rp 0" styleClass="card-value"/>
                </VBox>

            </HBox>

            <!-- ================= CHARTS ================= -->
            <HBox spacing="15">

                <VBox spacing="10" prefWidth="620" HBox.hgrow="ALWAYS" styleClass="card">

                    <HBox alignment="CENTER_LEFT">
                        <Label text="Material Incoming vs Outgoing (Last 7 Days)" styleClass="panel-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="&#8644;" styleClass="chart-header-icon"/>
                        <Label text="&#9432;" styleClass="chart-header-icon"/>
                    </HBox>

                    <AreaChart fx:id="flowChart" styleClass="chart-flow" legendVisible="true"
                               animated="false" createSymbols="true" prefHeight="280" minHeight="220"
                               VBox.vgrow="ALWAYS">
                        <xAxis>
                            <CategoryAxis side="BOTTOM"/>
                        </xAxis>
                        <yAxis>
                            <NumberAxis side="LEFT"/>
                        </yAxis>
                    </AreaChart>

                </VBox>

                <VBox spacing="10" prefWidth="380" HBox.hgrow="ALWAYS" styleClass="card">

                    <HBox alignment="CENTER_LEFT">
                        <Label text="Top Consumed Materials" styleClass="panel-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="&#9432;" styleClass="chart-header-icon"/>
                    </HBox>

                    <StackPane VBox.vgrow="ALWAYS" prefHeight="280" minHeight="220">
                        <BarChart fx:id="consumedChart" styleClass="chart-consumed"
                                  animated="false" legendVisible="false">
                            <xAxis>
                                <CategoryAxis side="BOTTOM"/>
                            </xAxis>
                            <yAxis>
                                <NumberAxis side="LEFT"/>
                            </yAxis>
                        </BarChart>
                        <Label fx:id="lblConsumedEmpty" text="No consumption data yet."
                               styleClass="empty-state-label" visible="false" managed="false"/>
                    </StackPane>

                </VBox>

            </HBox>

            <!-- ================= NOTIFICATIONS + ACTIVITY ================= -->
            <HBox spacing="15">

                <VBox spacing="10" prefWidth="620" HBox.hgrow="ALWAYS" styleClass="card">

                    <HBox alignment="CENTER_LEFT">
                        <Label text="Notifications / Low Stock Items" styleClass="panel-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="&#9881;" styleClass="chart-header-icon"/>
                    </HBox>

                    <ScrollPane fitToWidth="true" styleClass="inner-scroll" prefHeight="300" VBox.vgrow="ALWAYS">
                        <content>
                            <VBox fx:id="notificationContainer" spacing="12"/>
                        </content>
                    </ScrollPane>

                </VBox>

                <VBox spacing="10" prefWidth="380" HBox.hgrow="ALWAYS" styleClass="card">

                    <HBox alignment="CENTER_LEFT">
                        <Label text="Recent Activity Log" styleClass="panel-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="&#9776;" styleClass="chart-header-icon"/>
                    </HBox>

                    <ScrollPane fitToWidth="true" styleClass="inner-scroll" prefHeight="300" VBox.vgrow="ALWAYS">
                        <content>
                            <VBox fx:id="activityContainer" spacing="4"/>
                        </content>
                    </ScrollPane>

                </VBox>

            </HBox>

        </VBox>

    </content>

</ScrollPane>
