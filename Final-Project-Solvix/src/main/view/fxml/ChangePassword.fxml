<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="16" prefWidth="380" styleClass="card"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.stockin.controller.ChangePasswordController"
      stylesheets="@../css/style.css">

    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <Label text="Change Password" styleClass="section-title"/>

    <VBox spacing="6">
        <Label text="Current Password"/>
        <PasswordField fx:id="txtCurrentPassword" styleClass="password-field"/>
    </VBox>

    <VBox spacing="6">
        <Label text="New Password"/>
        <PasswordField fx:id="txtNewPassword" styleClass="password-field"/>
    </VBox>

    <VBox spacing="6">
        <Label text="Confirm New Password"/>
        <PasswordField fx:id="txtConfirmPassword" styleClass="password-field"/>
    </VBox>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#cancel"/>
        <Button text="Save" onAction="#savePassword" styleClass="btn-success"/>
    </HBox>

</VBox>
