<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.stockin.controller.ProductionController">

    <top>

        <VBox spacing="10">

            <Label text="Production"
                   style="-fx-font-size:22px;
                          -fx-font-weight:bold;"/>

            <GridPane hgap="10" vgap="10">

                <Label text="Product" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <ComboBox fx:id="cmbProduct" prefWidth="200" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Production Date" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                <DatePicker fx:id="dateProduction" prefWidth="150" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                <Label text="Expiration Date" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <DatePicker fx:id="dateExpired" prefWidth="150" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Selling Price" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                <TextField fx:id="txtSellingPrice" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                <Label text="Quantity Produced" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="txtQuantityProduced" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="Quantity Sold" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                <TextField fx:id="txtQuantitySold" GridPane.rowIndex="2" GridPane.columnIndex="3"/>

                <Label text="Note" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <TextField fx:id="txtNote" GridPane.rowIndex="3" GridPane.columnIndex="1"
                           GridPane.columnSpan="3"/>

            </GridPane>

            <Separator/>

            <Label text="Materials Used (optional, can select more than one material, stock will be reduced automatically when Added)"
                   style="-fx-font-weight:bold;"/>

            <GridPane hgap="10" vgap="10">

                <Label text="Material" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <ComboBox fx:id="cmbMaterialUsed" prefWidth="200" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Quantity Used" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                <TextField fx:id="txtMaterialQtyUsed" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                <Button text="+ Add Material" onAction="#addMaterialUsage"
                        GridPane.rowIndex="0" GridPane.columnIndex="4"/>

            </GridPane>

            <TableView fx:id="tableMaterialUsed" prefHeight="110">

                <columns>
                    <TableColumn fx:id="colMaterialUsedName" text="Material" prefWidth="220"/>
                    <TableColumn fx:id="colMaterialUsedQty" text="Quantity Used" prefWidth="150"/>
                </columns>

            </TableView>

            <HBox spacing="10">

                <Button text="Remove Selected Material" onAction="#removeMaterialUsage"/>

            </HBox>

            <HBox spacing="10">

                <Button text="Add" onAction="#saveProduction"/>
                <Button text="Update" onAction="#updateProduction"/>
                <Button text="Delete" onAction="#deleteProduction"/>
                <Button text="Reset" onAction="#clearForm"/>

            </HBox>

        </VBox>

    </top>

    <center>

        <TableView fx:id="tableProduction">

            <columns>

                <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                <TableColumn fx:id="colProduct" text="Product" prefWidth="140"/>
                <TableColumn fx:id="colProdDate" text="Production Date" prefWidth="100"/>
                <TableColumn fx:id="colExpDate" text="Expiry Date" prefWidth="110"/>
                <TableColumn fx:id="colProduced" text="Produced" prefWidth="90"/>
                <TableColumn fx:id="colSold" text="Sold" prefWidth="80"/>
                <TableColumn fx:id="colPrice" text="Selling Price" prefWidth="100"/>
                <TableColumn fx:id="colRevenue" text="Revenue" prefWidth="110"/>
                <TableColumn fx:id="colNote" text="Note" prefWidth="140"/>

            </columns>

        </TableView>

    </center>

    <padding>
        <Insets top="20" right="20" left="20" bottom="20"/>
    </padding>

</BorderPane>
