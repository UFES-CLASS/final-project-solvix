<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true"
            style="-fx-background-color:transparent; -fx-background: transparent;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.stockin.controller.MaterialController">

    <content>

        <VBox spacing="20" style="-fx-background-color:transparent;">

            <padding>
                <Insets top="0" right="4" bottom="20" left="0"/>
            </padding>

            <Label text="Material Management" styleClass="page-title"/>

            <!-- ================= ADD / EDIT FORM ================= -->
            <VBox spacing="16" styleClass="card">

                <Label text="Add / Edit Material" styleClass="panel-title"/>

                <HBox spacing="20">

                    <VBox spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <Label text="Material Name" styleClass="form-label"/>
                        <TextField fx:id="txtMaterialName" promptText="Material Name" styleClass="text-field"/>
                    </VBox>

                    <VBox spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <Label text="Category" styleClass="form-label"/>
                        <ComboBox fx:id="cmbCategory" editable="false" promptText="Select a category"
                                  maxWidth="Infinity" styleClass="combo-box"/>
                    </VBox>

                    <VBox spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <Label text="Unit" styleClass="form-label"/>
                        <TextField fx:id="txtUnit" promptText="Unit" styleClass="text-field"/>
                    </VBox>

                </HBox>

                <HBox spacing="20">

                    <VBox spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <Label text="Stock" styleClass="form-label"/>
                        <TextField fx:id="txtStock" promptText="Stock" styleClass="text-field"/>
                    </VBox>

                    <VBox fx:id="vboxMinimumStock" spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <Label text="Minimum Stock" styleClass="form-label"/>
                        <TextField fx:id="txtMinimumStock" promptText="Minimum Stock" styleClass="text-field"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                </HBox>

                <HBox spacing="12">
                    <Button text="&#10004;  Save Material" onAction="#saveMaterial" styleClass="btn-success"
                            HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button text="&#8634;  Clear Form" onAction="#clearForm" styleClass="btn-outline"
                            HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                </HBox>

            </VBox>

            <!-- ================= INVENTORY TABLE ================= -->
            <VBox spacing="14" styleClass="card">

                <Label text="Current Inventory Table" styleClass="panel-title"/>

                <HBox spacing="12" alignment="CENTER_LEFT">

                    <TextField fx:id="txtSearch" promptText="Search materials..."
                               styleClass="text-field" HBox.hgrow="ALWAYS"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Label text="Category:" styleClass="form-label"/>

                    <ComboBox fx:id="cmbCategoryFilter" prefWidth="150" styleClass="combo-box"/>

                </HBox>

                <TableView fx:id="tableMaterial" prefHeight="360" minHeight="240" VBox.vgrow="ALWAYS"
                           styleClass="table-view, table-view-light">

                    <columns>

                        <TableColumn fx:id="colId" text="ID" prefWidth="55"/>

                        <TableColumn fx:id="colName" text="Material Name" prefWidth="200"/>

                        <TableColumn fx:id="colCategory" text="Category" prefWidth="140"/>

                        <TableColumn fx:id="colUnit" text="Unit" prefWidth="90"/>

                        <TableColumn fx:id="colStock" text="Current Stock" prefWidth="150"/>

                        <TableColumn fx:id="colMinimum" text="Min. Stock" prefWidth="110"/>

                        <TableColumn fx:id="colActions" text="Actions" prefWidth="190" sortable="false"/>

                    </columns>

                </TableView>

            </VBox>

        </VBox>

    </content>

</ScrollPane>
