<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.stockin.controller.ReportController">

    <content>

        <VBox spacing="20" style="-fx-padding:20;">

            <Label text="Financial Report"
                   style="-fx-font-size:22px;
                          -fx-font-weight:bold;"/>

            <Label text="Revenue is calculated directly from Production data (no separate table)."
                   style="-fx-text-fill:#6B7280;"/>

            <!-- FILTER PERIODE -->
            <HBox spacing="10" alignment="CENTER_LEFT">

                <Label text="From"/>
                <DatePicker fx:id="dateFrom"/>

                <Label text="To"/>
                <DatePicker fx:id="dateTo"/>

                <Button text="Apply" onAction="#applyFilter"/>
                <Button text="Show All" onAction="#resetFilter"/>

            </HBox>

            <!-- SUMMARY CARDS -->
            <HBox spacing="15">

                <VBox spacing="5" prefWidth="220"
                      style="-fx-background-color:white; -fx-padding:15;
                             -fx-background-radius:8; -fx-border-color:#E5E7EB; -fx-border-radius:8;">
                    <Label text="Total Produced" style="-fx-text-fill:#6B7280;"/>
                    <Label fx:id="lblTotalProduced" text="0"
                           style="-fx-font-size:26; -fx-font-weight:bold; -fx-text-fill:#2563EB;"/>
                </VBox>

                <VBox spacing="5" prefWidth="220"
                      style="-fx-background-color:white; -fx-padding:15;
                             -fx-background-radius:8; -fx-border-color:#E5E7EB; -fx-border-radius:8;">
                    <Label text="Total Sold" style="-fx-text-fill:#6B7280;"/>
                    <Label fx:id="lblTotalSold" text="0"
                           style="-fx-font-size:26; -fx-font-weight:bold; -fx-text-fill:#2563EB;"/>
                </VBox>

                <VBox spacing="5" prefWidth="220"
                      style="-fx-background-color:white; -fx-padding:15;
                             -fx-background-radius:8; -fx-border-color:#E5E7EB; -fx-border-radius:8;">
                    <Label text="Revenue" style="-fx-text-fill:#6B7280;"/>
                    <Label fx:id="lblRevenue" text="Rp 0"
                           style="-fx-font-size:26; -fx-font-weight:bold; -fx-text-fill:#16A34A;"/>
                </VBox>

            </HBox>

            <!-- GRAFIK -->
            <HBox spacing="15">

                <BarChart fx:id="chartByProduct" prefWidth="480" prefHeight="300" title="Revenue per Product">
                    <xAxis>
                        <CategoryAxis label="Product"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Revenue (IDR)"/>
                    </yAxis>
                </BarChart>

                <LineChart fx:id="chartByDate" prefWidth="480" prefHeight="300" title="Revenue per Date">
                    <xAxis>
                        <CategoryAxis label="Date"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Revenue (IDR)"/>
                    </yAxis>
                </LineChart>

            </HBox>

            <!-- TABEL RINCIAN PER PRODUK -->
            <Label text="List of Product" style="-fx-font-size:16; -fx-font-weight:bold;"/>

            <TableView fx:id="tableSummary" prefHeight="220">

                <columns>

                    <TableColumn fx:id="colProduct" text="Product" prefWidth="220"/>
                    <TableColumn fx:id="colProduced" text="Total Produced" prefWidth="150"/>
                    <TableColumn fx:id="colSold" text="Total Sold" prefWidth="150"/>
                    <TableColumn fx:id="colRevenue" text="Revenue" prefWidth="180"/>

                </columns>

            </TableView>

        </VBox>

    </content>

</ScrollPane>
