<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.AreaChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true"
            style="-fx-background-color:transparent; -fx-background: transparent;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.stockin.controller.ReportController">

    <content>

        <VBox spacing="20" style="-fx-background-color:transparent;">

            <padding>
                <Insets top="0" right="4" bottom="20" left="0"/>
            </padding>

            <!-- ================= HEADER ================= -->
            <HBox alignment="CENTER_LEFT" spacing="12">

                <VBox spacing="2">
                    <Label text="Financial Report" styleClass="page-title"/>
                    <Label text="Revenue comes from Production records, Expense comes from Incoming Material purchases."
                           styleClass="report-subtitle"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <Label text="From" styleClass="report-date-label"/>
                <DatePicker fx:id="dateFrom" styleClass="text-field" prefWidth="150"/>

                <Label text="To" styleClass="report-date-label"/>
                <DatePicker fx:id="dateTo" styleClass="text-field" prefWidth="150"/>

                <Button text="Apply" onAction="#applyFilter" styleClass="btn-success"/>
                <Button text="View All" onAction="#resetFilter" styleClass="btn-outline"/>

            </HBox>

            <!-- ================= STAT CARDS ================= -->
            <!-- FlowPane dipakai (bukan HBox biasa) supaya kalau lebar layar
                 tidak cukup untuk menampilkan kelima kartu berdampingan,
                 kartu-kartu ini otomatis turun/bergeser ke baris di
                 bawahnya, bukan malah membuat tulisan seperti "Revenue"
                 terpotong / sulit dibaca. -->
            <FlowPane hgap="18" vgap="18">

                <VBox spacing="10" prefWidth="200" minWidth="180" styleClass="stat-card, stat-card-produced">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="&#128230;" styleClass="stat-card-icon-box"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="&#128200;" styleClass="stat-card-trend-icon"/>
                    </HBox>
                    <Label text="Total Produced" styleClass="stat-card-title" wrapText="true"/>
                    <Label fx:id="lblTotalProduced" text="0" styleClass="stat-card-value" wrapText="true"/>
                </VBox>

                <VBox spacing="10" prefWidth="200" minWidth="180" styleClass="stat-card, stat-card-sold">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="&#128717;" styleClass="stat-card-icon-box"/>
                        <Region HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <Label text="Total Sold" styleClass="stat-card-title" wrapText="true"/>
                    <Label fx:id="lblTotalSold" text="0" styleClass="stat-card-value" wrapText="true"/>
                </VBox>

                <VBox spacing="10" prefWidth="220" minWidth="200" styleClass="stat-card, stat-card-revenue">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="&#128176;" styleClass="stat-card-icon-box"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="&#128200;" styleClass="stat-card-trend-icon"/>
                    </HBox>
                    <Label text="Revenue (Income)" styleClass="stat-card-title" wrapText="true"/>
                    <Label fx:id="lblRevenue" text="Rp 0,00" styleClass="stat-card-value"
                           wrapText="true" prefWidth="190"/>
                </VBox>

                <VBox spacing="10" prefWidth="220" minWidth="200" styleClass="stat-card, stat-card-produced">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="&#128181;" styleClass="stat-card-icon-box"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="&#128201;" styleClass="stat-card-trend-icon"/>
                    </HBox>
                    <Label text="Expense (Material Purchases)" styleClass="stat-card-title" wrapText="true"/>
                    <Label fx:id="lblExpense" text="Rp 0,00" styleClass="stat-card-value"
                           wrapText="true" prefWidth="190"/>
                </VBox>

                <VBox spacing="10" prefWidth="220" minWidth="200" styleClass="stat-card, stat-card-sold">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="&#128184;" styleClass="stat-card-icon-box"/>
                        <Region HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <Label text="Profit (Revenue - Expense)" styleClass="stat-card-title" wrapText="true"/>
                    <Label fx:id="lblProfit" text="Rp 0,00" styleClass="stat-card-value"
                           wrapText="true" prefWidth="190"/>
                </VBox>

            </FlowPane>

            <!-- ================= CHARTS ================= -->
            <!-- GridPane dengan 2 kolom masing-masing 50% dipakai (bukan HBox biasa)
                 supaya kedua kartu chart SELALU dapat lebar yang sama persis,
                 walaupun chart di kiri jadi lebar sekali karena banyak produk
                 (kelebihannya di-scroll di dalam kartunya sendiri, tidak
                 mendorong / mengecilkan kartu "Revenue per Date" di sebelahnya). -->
            <GridPane hgap="18">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>

                <VBox spacing="10" maxWidth="Infinity" styleClass="card" GridPane.columnIndex="0">
                    <Label text="Revenue per Product" styleClass="report-chart-title"/>
                    <ScrollPane fx:id="chartByProductScroll" fitToHeight="true" fitToWidth="false"
                                hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                                style="-fx-background-color:transparent; -fx-background: transparent;"
                                prefWidth="0" prefHeight="290" minHeight="260" VBox.vgrow="ALWAYS">
                        <content>
                            <BarChart fx:id="chartByProduct" styleClass="report-bar-chart"
                                      animated="false" legendVisible="false"
                                      barGap="2" categoryGap="16"
                                      prefHeight="270" minHeight="260">
                                <xAxis>
                                    <CategoryAxis label="Product" side="BOTTOM"/>
                                </xAxis>
                                <yAxis>
                                    <NumberAxis label="Revenue (IDR)" side="LEFT"/>
                                </yAxis>
                            </BarChart>
                        </content>
                    </ScrollPane>
                </VBox>

                <VBox spacing="10" maxWidth="Infinity" styleClass="card" GridPane.columnIndex="1">
                    <Label text="Revenue per Date" styleClass="report-chart-title"/>
                    <AreaChart fx:id="chartByDate" styleClass="report-area-chart"
                               animated="false" legendVisible="false" createSymbols="true"
                               prefHeight="290" minHeight="260" VBox.vgrow="ALWAYS">
                        <xAxis>
                            <CategoryAxis label="Date" side="BOTTOM"/>
                        </xAxis>
                        <yAxis>
                            <NumberAxis label="Revenue (IDR)" side="LEFT"/>
                        </yAxis>
                    </AreaChart>
                </VBox>

            </GridPane>

            <!-- ================= PRODUCT LIST TABLE ================= -->
            <VBox spacing="14" styleClass="card">

                <Label text="List of Product" styleClass="panel-title"/>

                <TableView fx:id="tableSummary" styleClass="report-table" prefHeight="260" VBox.vgrow="ALWAYS">

                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>

                    <columns>

                        <TableColumn fx:id="colSelect" text="" prefWidth="42" minWidth="42" maxWidth="42" sortable="false"/>
                        <TableColumn fx:id="colProduct" text="Product" prefWidth="220"/>
                        <TableColumn fx:id="colProduced" text="Total Produced" prefWidth="150"/>
                        <TableColumn fx:id="colSold" text="Total Sold" prefWidth="130"/>
                        <TableColumn fx:id="colRevenue" text="Revenue" prefWidth="160"/>
                        <TableColumn fx:id="colSparkline" text="Sparkline Revenue" prefWidth="190" sortable="false"/>

                    </columns>

                </TableView>

            </VBox>

        </VBox>

    </content>

</ScrollPane>
