<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.stockin.controller.ProductController">

    <top>

        <VBox spacing="10">

            <Label text="Product Management"
                   style="-fx-font-size:22px;
                          -fx-font-weight:bold;"/>

            <HBox spacing="20">

                <VBox alignment="CENTER" spacing="8">

                    <ImageView fx:id="imgPreview" fitWidth="120" fitHeight="120" preserveRatio="true"/>

                    <Button text="Choose Image" onAction="#chooseImage"/>

                </VBox>

                <GridPane hgap="10" vgap="10" HBox.hgrow="ALWAYS">

                    <Label text="Product Name" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtProductName" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Selling Price" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                    <TextField fx:id="txtSellingPrice" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                    <Label text="Description" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtDescription" GridPane.rowIndex="1" GridPane.columnIndex="1"
                               GridPane.columnSpan="3"/>

                    <Label text="Active Status" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <CheckBox fx:id="chkActive" selected="true" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                </GridPane>

            </HBox>

            <HBox spacing="10">

                <Button text="Add" onAction="#saveProduct"/>
                <Button text="Update" onAction="#updateProduct"/>
                <Button text="Delete" onAction="#deleteProduct"/>
                <Button text="Reset" onAction="#clearForm"/>

            </HBox>

        </VBox>

    </top>

    <center>

        <TableView fx:id="tableProduct">

            <columns>

                <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                <TableColumn fx:id="colName" text="Product Name" prefWidth="200"/>
                <TableColumn fx:id="colDescription" text="Description" prefWidth="220"/>
                <TableColumn fx:id="colPrice" text="Selling Price" prefWidth="120"/>
                <TableColumn fx:id="colActive" text="Active" prefWidth="80"/>

            </columns>

        </TableView>

    </center>

    <padding>
        <Insets top="20" right="20" left="20" bottom="20"/>
    </padding>

</BorderPane>
