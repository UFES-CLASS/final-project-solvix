<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.stockin.controller.DashboardHomeController">

    <padding>
        <Insets top="0" right="0" bottom="0" left="0"/>
    </padding>

    <Label text="Dashboard" styleClass="page-title"/>

    <!-- STATISTIC CARDS -->
    <HBox spacing="15">

        <VBox spacing="8" prefWidth="200" styleClass="card">
            <Label text="Total Material" styleClass="card-title"/>
            <Label fx:id="lblMaterial" text="0" styleClass="card-value"/>
        </VBox>

        <VBox spacing="8" prefWidth="200" styleClass="card">
            <Label text="Total Product" styleClass="card-title"/>
            <Label fx:id="lblProduct" text="0" styleClass="card-value"/>
        </VBox>

        <VBox spacing="8" prefWidth="200" styleClass="card">
            <Label text="Incoming Hari Ini" styleClass="card-title"/>
            <Label fx:id="lblIncoming" text="0" styleClass="card-value"/>
        </VBox>

        <VBox spacing="8" prefWidth="200" styleClass="card">
            <Label text="Stok Menipis" styleClass="card-title"/>
            <Label fx:id="lblLowStock" text="0" styleClass="card-value" style="-fx-text-fill:#E53935;"/>
        </VBox>

    </HBox>

    <!-- RECENT ACTIVITY -->
    <VBox spacing="10" styleClass="card" VBox.vgrow="ALWAYS">

        <Label text="Notifikasi / Stok Menipis Terbaru" styleClass="section-title"/>

        <ListView fx:id="activityList"
                  VBox.vgrow="ALWAYS"/>

    </VBox>

</VBox>
