<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.stockin.controller.NotificationController">

    <top>

        <VBox spacing="10">

            <Label text="Notification"
                   style="-fx-font-size:22px;
                          -fx-font-weight:bold;"/>

            <Label fx:id="lblUnreadCount" text="0 unread notifications"
                   style="-fx-text-fill:#DC2626; -fx-font-weight:bold;"/>

            <HBox spacing="10">

                <Button text="Mark as Read" onAction="#markAsRead"/>
                <Button text="Mark All as Read" onAction="#markAllAsRead"/>
                <Button text="Delete" onAction="#deleteNotification"/>
                <Button text="Refresh" onAction="#refresh"/>

            </HBox>

        </VBox>

    </top>

    <center>

        <TableView fx:id="tableNotification">

            <columns>

                <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                <TableColumn fx:id="colMaterial" text="Material" prefWidth="150"/>
                <TableColumn fx:id="colMessage" text="Message" prefWidth="320"/>
                <TableColumn fx:id="colCreatedAt" text="Created At" prefWidth="150"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>

            </columns>

        </TableView>

    </center>

    <padding>
        <Insets top="20" right="20" left="20" bottom="20"/>
    </padding>

</BorderPane>
